{
  "manifest_version": 3,
  "name": "Better MS XDR",
  "version": "1.0.0",
  "description": "Adds some visual tweaks to the Microsoft Defender XDR UI.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://security.microsoft.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["theme-bridge.js"],
      "matches": ["https://security.microsoft.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
